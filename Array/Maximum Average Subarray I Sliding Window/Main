public class Main {
    public static double findMaxAverage(int[] nums, int k) {
        // 1. Pehli k elements ka sum nikal lo
        double currentSum = 0;
        for (int i = 0; i < k; i++) {
            currentSum += nums[i];
        }

        double maxSum = currentSum;

        // 2. Window ko "Slide" karo
        for (int i = k; i < nums.length; i++) {
            // Naya element add karo, aur purana (jo i-k par hai) minus karo
            currentSum += nums[i] - nums[i - k];
            
            // Max sum update karo
            if (currentSum > maxSum) {
                maxSum = currentSum;
            }
        }

        // 3. Average return karo
        return maxSum / k;
    }

    public static void main(String[] args) {
        int[] arr = {1, 12, -5, -6, 50, 3};
        int k = 4;
        System.out.println("Maximum Average: " + findMaxAverage(arr, k));
    }
}
